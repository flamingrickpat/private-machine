        <mxCell id="Sf5BCupqHHkOQp_wS39m-2" value="sensation = {&lt;br/&gt;    &lt;span class=&quot;hljs-string&quot;&gt;&quot;text&quot;&lt;/span&gt;: &lt;span class=&quot;hljs-string&quot;&gt;&quot;Why didn&#39;t you respond earlier?&quot;&lt;/span&gt;,&amp;nbsp;&lt;div&gt;&amp;nbsp;    &lt;span class=&quot;hljs-string&quot;&gt;&quot;tone&quot;&lt;/span&gt;: &lt;span class=&quot;hljs-string&quot;&gt;&quot;irritated&quot;&lt;/span&gt;,&lt;br/&gt;    &lt;span class=&quot;hljs-string&quot;&gt;&quot;relationship&quot;&lt;/span&gt;: {&lt;br/&gt;        &lt;span class=&quot;hljs-string&quot;&gt;&quot;closeness&quot;&lt;/span&gt;: &lt;span class=&quot;hljs-number&quot;&gt;0.7&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;hljs-string&quot;&gt;&quot;trust_level&quot;&lt;/span&gt;: &lt;span class=&quot;hljs-number&quot;&gt;0.8&lt;/span&gt;,&lt;br/&gt;        &lt;span class=&quot;hljs-string&quot;&gt;&quot;power_dynamics&quot;&lt;/span&gt;: &lt;span class=&quot;hljs-string&quot;&gt;&quot;peer&quot;&lt;/span&gt;,&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp;        &lt;span class=&quot;hljs-string&quot;&gt;&quot;interaction_history&quot;&lt;/span&gt;: [&lt;span class=&quot;hljs-string&quot;&gt;&quot;positive&quot;&lt;/span&gt;, &lt;span class=&quot;hljs-string&quot;&gt;&quot;neutral&quot;&lt;/span&gt;]&lt;br/&gt;    }&lt;br/&gt;}&lt;/div&gt;" style="align=left;strokeColor=none;fillColor=none;spacingLeft=4;fontSize=12;verticalAlign=top;resizable=1;rotatable=0;part=1;html=1;" parent="Sf5BCupqHHkOQp_wS39m-1" vertex="1">
