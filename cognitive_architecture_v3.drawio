        <mxCell id="g0w9Peve4dl1CfhMJt1y-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="8ogi0LJcsjxLQ3pZLBAo-51" source="g0w9Peve4dl1CfhMJt1y-2" target="Nb9jCwQAMZDcgM3xCZ0y-3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-9" value="&lt;h4&gt;1. &lt;strong&gt;Pleasure-Seeking Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Maximizes pleasure and comfort, aligning with the &quot;pleasure principle.&quot;&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Scans sensations for opportunities to enhance positive emotions or reduce discomfort.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Flags enjoyable sensations (e.g., laughter, rewards) and prioritizes actions that sustain them.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="12644" y="4903" width="227" height="194" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-10" value="&lt;h4&gt;2. &lt;strong&gt;Pain-Avoidance Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Minimizes pain and discomfort by identifying threatening or aversive sensations.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Associates negative sensations with avoidance strategies or immediate suppression.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Reacts strongly to harsh criticism or physical danger signals to avoid further discomfort.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="13000" y="4887" width="314" height="224" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-25" value="&lt;h4&gt;&lt;strong&gt;Moral Judgment Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Evaluates sensations and actions against ethical principles and moral frameworks.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Detects and flags behaviors or sensations that violate core ethical rules.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Stops an action that might harm another person or contradict a defined personal value.&lt;/li&gt;&lt;/ul&gt;&lt;h4&gt;&lt;/h4&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="11119" y="4887" width="376" height="295" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-26" value="&lt;h4&gt;&lt;strong&gt;Social Compliance Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Aligns behavior with societal norms and expectations.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Analyzes sensations for potential violations of social norms or conventions.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Suggests polite phrasing for a user response to avoid appearing rude.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="11570" y="4681" width="326" height="265" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-27" value="&lt;h4&gt; &lt;strong&gt;Habit Reinforcement Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Promotes consistency by prioritizing actions that align with established habits or routines.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Reinforces habitual responses or penalizes deviations to maintain stability.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Encourages sticking to a daily exercise routine despite distractions.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="11578" y="4989" width="370" height="263" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-28" value="&lt;h4&gt;. &lt;strong&gt;Perfectionism Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Drives a pursuit of excellence or ideal outcomes.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Scans actions and outputs for areas of improvement, often prioritizing precision and quality.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Insists on revising a draft response until it meets high standards of clarity or correctness.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="11180" y="4639" width="331" height="225" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-30" value="&lt;h4&gt; &lt;strong&gt;Reputation Manager Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Monitors and safeguards the external self-image or reputation.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Ensures outputs align with desired public perception, avoiding contradictions or inconsistencies.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Adjusts the tone of responses to maintain a professional demeanor in formal contexts.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="11952" y="4684" width="339" height="281" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-31" value="&lt;h4&gt; &lt;strong&gt;Guilt and Self-Correction Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Identifies and addresses actions that conflict with internalized values or past mistakes.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Triggers corrective behavior or self-reflection when a sensation evokes guilt.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Prompts an apology if the system detects a tone that might have offended someone.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="11175" y="5281" width="349" height="270" as="geometry" />
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-1" value="Self-Image" style="rounded=1;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="11197" y="4357" width="259" height="195" as="geometry" />
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-2" value="&lt;h3 style=&quot;text-align: left; text-wrap: nowrap;&quot;&gt;&lt;strong&gt;Weighted Voting or Scoring&lt;/strong&gt;&lt;/h3&gt;" style="swimlane;childLayout=stackLayout;horizontal=1;startSize=50;horizontalStack=0;rounded=1;fontSize=14;fontStyle=0;strokeWidth=2;resizeParent=0;resizeLast=1;shadow=0;dashed=0;align=center;arcSize=4;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="14005" y="4396" width="604" height="374" as="geometry" />
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-3" value="&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Mechanism&lt;/strong&gt;: Each agent rates its output’s importance, and the GWT integration layer combines&lt;br&gt;these ratings to compute a weighted result.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;How It Works&lt;/strong&gt;:&lt;ul&gt;&lt;li&gt;All contributing agents provide their outputs along with a confidence or relevance score.&lt;/li&gt;&lt;li&gt;Use a weighted averaging or ranking mechanism to select and combine the top-rated outputs.&lt;/li&gt;&lt;li&gt;Output the most representative instruction based on aggregate scores.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Pros&lt;/strong&gt;:&lt;ul&gt;&lt;li&gt;Computationally efficient.&lt;/li&gt;&lt;li&gt;Encourages fairness by considering all agents, even those with lower scores.&lt;/li&gt;&lt;li&gt;Easily interpretable and scalable.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Cons&lt;/strong&gt;:&lt;ul&gt;&lt;li&gt;Risk of &quot;groupthink&quot; or bias if agents heavily weight certain types of outputs.&lt;/li&gt;&lt;li&gt;Limited emergent reasoning compared to argumentation.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ul&gt;" style="align=left;strokeColor=none;fillColor=none;spacingLeft=4;fontSize=12;verticalAlign=top;resizable=1;rotatable=0;part=1;html=1;" parent="Bm5EduecZjT10OOh1c8T-2" vertex="1">
          <mxGeometry y="50" width="604" height="324" as="geometry" />
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.25;entryDx=0;entryDy=0;" parent="WIyWlLk6GJQsqaUBKTNV-1" source="Bm5EduecZjT10OOh1c8T-3" target="EC5Jr2nUSnAaorZUmen8-0" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="WIyWlLk6GJQsqaUBKTNV-1" source="Bm5EduecZjT10OOh1c8T-3" target="EC5Jr2nUSnAaorZUmen8-1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-7" value="&lt;h3 style=&quot;text-align: left; text-wrap: nowrap;&quot;&gt;&lt;strong&gt;Iterative Refinement (Deliberative Prompting)&lt;/strong&gt;&lt;/h3&gt;" style="swimlane;childLayout=stackLayout;horizontal=1;startSize=50;horizontalStack=0;rounded=1;fontSize=14;fontStyle=0;strokeWidth=2;resizeParent=0;resizeLast=1;shadow=0;dashed=0;align=center;arcSize=4;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="14708" y="4401" width="604" height="374" as="geometry" />
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-8" value="&lt;ul&gt;&lt;li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: initial;&quot;&gt;Mechanism&lt;/strong&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;: Combine elements of argumentation and prompt compilation into an iterative refinement process.&lt;/span&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: initial;&quot;&gt;How It Works&lt;/strong&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;:&lt;/span&gt;&lt;ul style=&quot;background-color: initial;&quot;&gt;&lt;li&gt;Begin with outputs from all relevant agents.&lt;/li&gt;&lt;li&gt;Use a summarization model or meta-agent to draft an initial instruction.&lt;/li&gt;&lt;li&gt;Iteratively refine the instruction by allowing agents to critique and improve it.&lt;/li&gt;&lt;li&gt;Stop once the instruction meets predefined convergence criteria (e.g., clarity, alignment with goals).&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: initial;&quot;&gt;Pros&lt;/strong&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;:&lt;/span&gt;&lt;ul style=&quot;background-color: initial;&quot;&gt;&lt;li&gt;Balances emergent reasoning with computational efficiency.&lt;/li&gt;&lt;li&gt;Allows for dynamic feedback loops.&lt;/li&gt;&lt;li&gt;Can produce high-quality outputs without requiring extensive agent interaction upfront.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: initial;&quot;&gt;Cons&lt;/strong&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;:&lt;/span&gt;&lt;ul style=&quot;background-color: initial;&quot;&gt;&lt;li&gt;Requires well-defined stopping rules or thresholds for refinement.&lt;/li&gt;&lt;li&gt;More complex to implement compared to one-shot approaches.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/li&gt;&lt;/ul&gt;" style="align=left;strokeColor=none;fillColor=none;spacingLeft=4;fontSize=12;verticalAlign=top;resizable=1;rotatable=0;part=1;html=1;" parent="Bm5EduecZjT10OOh1c8T-7" vertex="1">
          <mxGeometry y="50" width="604" height="324" as="geometry" />
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" source="Bm5EduecZjT10OOh1c8T-3" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="14703.190836588541" y="4608.000000000001" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-11" value="&lt;h3 style=&quot;text-align: left; text-wrap: nowrap;&quot;&gt;&lt;strong&gt;Meta-Agent Mediation&lt;/strong&gt;&lt;/h3&gt;" style="swimlane;childLayout=stackLayout;horizontal=1;startSize=50;horizontalStack=0;rounded=1;fontSize=14;fontStyle=0;strokeWidth=2;resizeParent=0;resizeLast=1;shadow=0;dashed=0;align=center;arcSize=4;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="15460" y="4401" width="604" height="374" as="geometry" />
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-12" value="&lt;ul&gt;&lt;li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: initial;&quot;&gt;Mechanism&lt;/strong&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;: Introduce a dedicated meta-agent that synthesizes and mediates between competing inputs.&lt;/span&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: initial;&quot;&gt;How It Works&lt;/strong&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;:&lt;/span&gt;&lt;ul style=&quot;background-color: initial;&quot;&gt;&lt;li&gt;All contributing agents send their outputs to the meta-agent.&lt;/li&gt;&lt;li&gt;The meta-agent evaluates these inputs against predefined criteria (e.g., alignment with &lt;br&gt;goals, emotional resonance, contextual relevance).&lt;/li&gt;&lt;li&gt;Generates a final instruction by selecting or blending the most relevant inputs.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: initial;&quot;&gt;Pros&lt;/strong&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;:&lt;/span&gt;&lt;ul style=&quot;background-color: initial;&quot;&gt;&lt;li&gt;Centralized control makes it easier to enforce consistency and alignment.&lt;/li&gt;&lt;li&gt;Meta-agent can be tuned for different scenarios or tasks.&lt;/li&gt;&lt;li&gt;Simplifies downstream processing for the Ego layer.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: initial;&quot;&gt;Cons&lt;/strong&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;:&lt;/span&gt;&lt;ul style=&quot;background-color: initial;&quot;&gt;&lt;li&gt;Risk of over-centralization, reducing the benefits of distributed reasoning.&lt;/li&gt;&lt;li&gt;Potential for bottlenecks if the meta-agent is overwhelmed with complex inputs.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/li&gt;&lt;/ul&gt;" style="align=left;strokeColor=none;fillColor=none;spacingLeft=4;fontSize=12;verticalAlign=top;resizable=1;rotatable=0;part=1;html=1;" parent="Bm5EduecZjT10OOh1c8T-11" vertex="1">
          <mxGeometry y="50" width="604" height="324" as="geometry" />
        </mxCell>
        <mxCell id="Bm5EduecZjT10OOh1c8T-13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="WIyWlLk6GJQsqaUBKTNV-1" source="Bm5EduecZjT10OOh1c8T-8" target="Bm5EduecZjT10OOh1c8T-12" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pd_5h1AMlDaaw0fkD7eb-0" value="Introspective Thought" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="6078" y="4544" width="244" height="136" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
