        <mxCell id="2ho36PFjFaWToWEbiMz6-0" value="&lt;p&gt;&lt;strong&gt;Relevance Agent&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Determines whether the sensation aligns with current goals, tasks, or context.&lt;/li&gt;&lt;li&gt;Example: If the user is focused on solving a problem, irrelevant distractions are filtered out.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-78" vertex="1">
          <mxGeometry x="2295" y="235" width="306" height="166" as="geometry" />
        </mxCell>
        <mxCell id="2ho36PFjFaWToWEbiMz6-2" value="&lt;p&gt;&lt;strong&gt;Urgency Agent&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Evaluates the time-sensitivity of the sensation.&lt;/li&gt;&lt;li&gt;Example: A request to turn off an alarm might take precedence over a casual user query.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-78" vertex="1">
          <mxGeometry x="2295" y="418" width="325" height="129" as="geometry" />
        </mxCell>
        <mxCell id="2ho36PFjFaWToWEbiMz6-3" value="&lt;p&gt;&lt;strong&gt;Task Relevance Agent&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Checks if the sensation pertains to ongoing tasks or active tools.&lt;/li&gt;&lt;li&gt;Example: While writing code, an unrelated thought about cats might be deprioritized.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-78" vertex="1">
          <mxGeometry x="2295" y="571" width="315" height="137" as="geometry" />
        </mxCell>
        <mxCell id="2ho36PFjFaWToWEbiMz6-4" value="&lt;p&gt;&lt;strong&gt;Redundancy Agent&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Identifies sensations similar to recently processed ones and prevents them from re-entering the pipeline.&lt;/li&gt;&lt;li&gt;Example: If the system has already responded to a user query, follow-up pings might be deprioritized.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-78" vertex="1">
          <mxGeometry x="2295" y="727" width="341" height="127" as="geometry" />
        </mxCell>
        <mxCell id="2ho36PFjFaWToWEbiMz6-5" value="&lt;p&gt;&lt;strong&gt;Focus Agent&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Enforces a &quot;focus mode,&quot; prioritizing sensations that match a currently active task or context.&lt;/li&gt;&lt;li&gt;Example: While writing a report, this agent suppresses non-essential distractions.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-78" vertex="1">
          <mxGeometry x="2295" y="873" width="299" height="110" as="geometry" />
        </mxCell>
        <mxCell id="2ho36PFjFaWToWEbiMz6-6" value="&lt;p&gt;&lt;strong&gt;Meta-Sensation Agent&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Monitors the system’s internal state (e.g., cognitive load, fatigue) to dynamically adjust the filtering threshold.&lt;/li&gt;&lt;li&gt;Example: If the system detects that it’s overwhelmed, it raises the threshold to reduce input volume.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-78" vertex="1">
          <mxGeometry x="2295" y="32" width="330" height="196" as="geometry" />
        </mxCell>
        <mxCell id="2ho36PFjFaWToWEbiMz6-13" value="pre_sensation_filter" style="swimlane;childLayout=stackLayout;horizontal=1;startSize=50;horizontalStack=0;rounded=1;fontSize=14;fontStyle=0;strokeWidth=2;resizeParent=0;resizeLast=1;shadow=0;dashed=0;align=center;arcSize=4;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-78" vertex="1">
