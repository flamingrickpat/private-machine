        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-20" value="&lt;h4&gt;3. &lt;strong&gt;Drive Fulfillment Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Ensures that core drives (hunger, sleep, safety, curiosity) are acknowledged and pursued.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Monitors unmet needs and generates high-priority signals when drives are unfulfilled.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Generates an urgency signal if a &quot;hunger drive&quot; sensation is detected.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-79" vertex="1">
          <mxGeometry x="2493" y="-349" width="304" height="214" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-21" value="&lt;h4&gt;4. &lt;strong&gt;Impulse Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Generates spontaneous, often irrational desires or urges.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Processes fleeting sensations or thoughts that reflect sudden wants, like indulgence or risk-taking.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Promotes actions like impulsively eating dessert or exploring a novel idea.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-79" vertex="1">
          <mxGeometry x="1722" y="-110" width="303" height="230" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-22" value="&lt;h4&gt;&lt;strong&gt;Fantasy Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Creates and maintains idealized or escapist scenarios in response to unmet desires or boredom.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Generates &quot;wish fulfillment&quot; thoughts or imaginations to satisfy long-term unmet goals.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: Imagines an exotic vacation when processing a sensation of monotony or frustration.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-79" vertex="1">
          <mxGeometry x="2097" y="-98" width="357" height="265" as="geometry" />
        </mxCell>
        <mxCell id="Sf5BCupqHHkOQp_wS39m-23" value="&lt;h4&gt; &lt;strong&gt;Emotional Resonance Agent&lt;/strong&gt;&lt;/h4&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Purpose&lt;/strong&gt;: Amplifies or spreads emotional states across related sensations.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Functionality&lt;/strong&gt;: Associates current emotions with previous experiences or stimuli to create consistent emotional patterns.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Example&lt;/strong&gt;: If sadness is detected, it might resurface memories or thoughts tied to past losses.&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="8ogi0LJcsjxLQ3pZLBAo-79" vertex="1">
          <mxGeometry x="2524" y="-55" width="315" height="250" as="geometry" />
        </mxCell>
